{
	"name": "olum",
	"displayName": "olum",
	"description": "Syntax highlighting, IntelliSense, navigation and diagnostics for the Olum HTML framework",
	"publisher": "eissapk",
	"icon": "assets/logo.png",
	"author": "Eissa Saber",
	"version": "1.0.1",
	"engines": {
		"vscode": "^1.75.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Other"
	],
	"activationEvents": [
		"onLanguage:html"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "olum.fixComponentCase",
				"title": "Fix Component Case",
				"category": "Olum"
			}
		],
		"languages": [
			{
				"id": "html",
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"scopeName": "scss.injection",
				"path": "./syntax/scss.injection.json",
				"injectTo": [
					"text.html"
				],
				"embeddedLanguages": {
					"source.css.scss": "scss",
					"source.sass": "sass"
				}
			}
		],
		"snippets": [
			{
				"language": "html",
				"path": "./snippets/snippets.code-snippets"
			},
			{
				"language": "javascript",
				"path": "./snippets/snippets.code-snippets"
			}
		],
		"configurationDefaults": {
			"[html]": {
				"editor.defaultFormatter": "eissapk.olum"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/olumjs/olum-vsc.git"
	},
	"bugs": {
		"url": "https://github.com/olumjs/olum-vsc/issues"
	},
	"homepage": "https://github.com/olumjs/olum-vsc#readme",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"typecheck": "tsc -p ./ --noEmit"
	},
	"devDependencies": {
		"@types/js-beautify": "^1.14.3",
		"@types/node": "^18.19.0",
		"@types/vscode": "^1.75.0",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"js-beautify": "^1.15.4"
	}
}
